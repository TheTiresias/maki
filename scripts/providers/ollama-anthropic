#!/usr/bin/env python3
"""
Ollama dynamic provider for maki (Anthropic-compatible API).

Install: cp scripts/providers/ollama-anthropic ~/.maki/providers/ollama-anthropic && chmod +x ~/.maki/providers/ollama-anthropic
Usage:   maki -m ollama-anthropic/llama3.2

Uses Ollama's Anthropic-compatible API:
https://docs.ollama.com/api/anthropic-compatibility
"""

import json
import os
import sys

DEFAULT_HOST = "http://localhost:11434"
OLLAMA_HOST = os.environ.get("OLLAMA_HOST", DEFAULT_HOST)


def cmd_info():
    print(json.dumps({
        "display_name": "Ollama (Anthropic API)",
        "base": "anthropic",
        "has_auth": False,
    }))


def cmd_resolve():
    print(json.dumps({
        "base_url": f"{OLLAMA_HOST}/v1/messages",
        "headers": {
            "x-api-key": "ollama",
        },
    }))


def cmd_refresh():
    cmd_resolve()


def main():
    if len(sys.argv) < 2:
        print(f"usage: {sys.argv[0]} <info|resolve|refresh>", file=sys.stderr)
        sys.exit(1)

    cmd = sys.argv[1]
    commands = {
        "info": cmd_info,
        "resolve": cmd_resolve,
        "refresh": cmd_refresh,
    }

    fn = commands.get(cmd)
    if not fn:
        print(f"unknown command: {cmd}", file=sys.stderr)
        sys.exit(1)
    fn()


if __name__ == "__main__":
    main()
